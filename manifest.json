{
  "name": "Pintergif",
  "version": "2.0",
  "description": "Autoplay for GIFs on Pinterest.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/pintergif16.png",
      "32": "images/pintergif32.png",
      "48": "images/pintergif48.png",
      "128": "images/pintergif128.png"
    }
  },
  "content_scripts": [{
    "matches": [
      "*://*.pinterest.com/*",
      "*://*.pinterest.at/*",
      "*://*.pinterest.ca/*",
      "*://*.pinterest.ch/*",
      "*://*.pinterest.cl/*",
      "*://*.pinterest.co/*",
      "*://*.pinterest.co.in/*",
      "*://*.pinterest.co.kr/*",
      "*://*.pinterest.co.nz/*",
      "*://*.pinterest.co.uk/*",
      "*://*.pinterest.com.au/*",
      "*://*.pinterest.com.br/*",
      "*://*.pinterest.com.mx/*",
      "*://*.pinterest.cz/*",
      "*://*.pinterest.de/*",
      "*://*.pinterest.dk/*",
      "*://*.pinterest.es/*",
      "*://*.pinterest.fi/*",
      "*://*.pinterest.fr/*",
      "*://*.pinterest.hu/*",
      "*://*.pinterest.id/*",
      "*://*.pinterest.ie/*",
      "*://*.pinterest.in/*",
      "*://*.pinterest.it/*",
      "*://*.pinterest.jp/*",
      "*://*.pinterest.kr/*",
      "*://*.pinterest.nl/*",
      "*://*.pinterest.nz/*",
      "*://*.pinterest.ph/*",
      "*://*.pinterest.pl/*",
      "*://*.pinterest.pt/*",
      "*://*.pinterest.ru/*",
      "*://*.pinterest.se/*",
      "*://*.pinterest.th/*",
      "*://*.pinterest.tw/*",
      "*://*.pinterest.uk/*"
    ],
    "js": ["defaults.js", "pintergif.js"]
  }],
  "icons": {
    "16": "images/pintergif16.png",
    "32": "images/pintergif32.png",
    "48": "images/pintergif48.png",
    "128": "images/pintergif128.png"
  },
  "manifest_version": 3
}
